# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter/Android local machine config (SDK paths, not for VCS)
/android/local.properties
**/android/key.properties
*.keystore
*.jks

# Python (proxy / admin / services)
.venv/
__pycache__/
*.pyc

# Secrets / runtime state — NEVER commit
.env
.env.*
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
proxy.log
admin.log

# Editor
.vscode/
.idea/

# Google OAuth client secret (never commit)
client_secret_*.json
assets/models/*.onnx
*.p8
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# Firebase service-account (FCM v1 send) — SECRET, never commit
*firebase-adminsdk*.json
